generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum ReminderStatus {
  pending
  sent
  cancelled
  failed
}

enum GoalStatus {
  active
  paused
  completed
}

model User {
  id            String                @id @default(cuid())
  name          String
  preferredName String?
  timezone      String                @default("America/Sao_Paulo")
  identities    IntegrationIdentity[]
  tasks         Task[]
  reminders     Reminder[]
  goals         Goal[]
  facts         UserFact[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model IntegrationIdentity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String
  externalId  String
  username    String?
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([provider, externalId])
  @@index([userId, provider])
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus   @default(pending)
  priority    TaskPriority @default(medium)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, status])
}

model Reminder {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  message    String
  remindAt   DateTime
  recurrence String?
  status     ReminderStatus @default(pending)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status, remindAt])
  @@index([userId])
}

model Goal {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String
  schedule    String?
  triggerAt   DateTime?
  status      GoalStatus @default(active)
  lastRunAt   DateTime?
  lastOutput  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, status])
}

model UserFact {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   String
  fact       String
  confidence Float    @default(0.7)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, createdAt])
}
