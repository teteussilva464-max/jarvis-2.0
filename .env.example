# =============================================================================
# JARVIS API
# =============================================================================

# Gere com: openssl rand -hex 32
JARVIS_API_KEY=
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
DEFAULT_USER_ID=user_default
USER_TIMEZONE=America/Sao_Paulo

# =============================================================================
# Banco de dados PostgreSQL
# =============================================================================

DATABASE_URL=postgresql://jarvis:SENHA_FORTE@localhost:5432/jarvis2_db

# Usado pelo docker-compose.yml para criar o container PostgreSQL
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=SENHA_FORTE
POSTGRES_DB=jarvis2_db

# =============================================================================
# OpenClaw
# =============================================================================

# Caminho do workspace do OpenClaw. Vazio usa o default: ~/.openclaw/workspace
OPENCLAW_WORKSPACE=

OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
JARVIS_API_URL=http://localhost:3001

# =============================================================================
# Modelos usados pelo OpenClaw
# =============================================================================

GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3-codex

# =============================================================================
# Busca web
# =============================================================================

TAVILY_API_KEY=
SEARXNG_URL=http://localhost:8888
SERPER_API_KEY=

# =============================================================================
# Smart Home — TuyaClaw
# =============================================================================

TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
TUYA_REGION=us

# =============================================================================
# Discord — canal gerenciado pelo OpenClaw
# =============================================================================

DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# WhatsApp: canal nativo via plugin @openclaw/whatsapp (QR scan; sem env obrigatória aqui)

# =============================================================================
# ClawLink / OAuth opcionais
# =============================================================================

CLAWLINK_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
